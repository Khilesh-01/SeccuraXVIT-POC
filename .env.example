# ── Copy to .env and fill in values ───────────────────────────────────────────

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=mySecret@123

# File TTL in seconds (default 15 min)
DOCUMENT_TTL_SECONDS=900

# Max upload size in MB
MAX_FILE_MB=20

# ── Phase 3: AI Agent ──────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
# Leave blank to run in regex-fallback mode (no Gemini calls)
GEMINI_API_KEY=

# Save per-agent debug JSON snapshots to /tmp/debug_outputs/
DEBUG_AGENT=true

# ── LangSmith Monitoring ──────────────────────────────────────────────────────
# Sign up at https://smith.langchain.com and create an API key
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=DocVerify-AI
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# Legacy aliases (backward compatibility)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=DocVerify-AI
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
